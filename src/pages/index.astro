---
import { GithubLogoIcon, XLogoIcon } from '@phosphor-icons/react'
import { CommandCopy } from '../components/CommandCopy'
import { InputGravityHero } from '../components/InputGravityHero'
import { IntegrationLogos } from '../components/IntegrationLogos'
import Layout from '../layouts/layout.astro'

const evidenceFiles = [
  ['customer-calls.csv', 'Quotes, objections, urgency'],
  ['support.slack', 'Repeated pain and broken flows'],
  ['posthog-notes.png', 'Activation gaps and drop-offs'],
  ['github-issues.md', 'Bugs, requests, repo context'],
  ['roadmap-debate.md', 'Bets, constraints, tradeoffs'],
]

const memoryRows = [
  ['surface', 'onboarding', 'users, friction, constraints, recent changes'],
  ['context', 'pricing', 'market notes, positioning, open questions'],
  ['proposal', 'empty-state-v2', 'evidence, options, tradeoffs, decision trail'],
  ['handoff', 'accepted', 'scope, acceptance criteria, risks'],
]

const loop = [
  {
    step: '01',
    title: 'Analyze',
    command: '/pm0 analyze onboarding',
    body: 'Inspect a product surface and write down what is true before the agent changes it.',
  },
  {
    step: '02',
    title: 'Discuss',
    command: '/pm0 discuss activation',
    body: 'Turn founder instinct, customer evidence, and team debate into options with tradeoffs.',
  },
  {
    step: '03',
    title: 'Build',
    command: '/pm0 build empty-state-v2',
    body: 'Scope the smallest useful prototype or code change with the product context attached.',
  },
  {
    step: '04',
    title: 'Handoff',
    command: '/pm0 handoff empty-state-v2',
    body: 'Accept, reject, or turn the decision into an engineering-ready PRD.',
  },
]

const principles = [
  'Durable product context lives in .pm0/ beside the code.',
  'Every proposal carries evidence, options, tradeoffs, and the decision trail.',
  'Rejected ideas update memory so agents do not repeat bad paths.',
]
---

<Layout>
  <main class='min-h-dvh overflow-x-clip bg-paper text-ink'>
    <section class='notebook-page relative isolate min-h-[92svh] overflow-hidden border-b border-ink px-5 pt-5 sm:px-8 lg:px-12'>
      <InputGravityHero client:load />
      <div class='pointer-events-none absolute inset-y-0 left-0 z-[1] hidden w-[68%] bg-linear-to-r from-paper via-paper/94 to-transparent lg:block'></div>
      <div class='pointer-events-none absolute inset-y-0 right-0 z-[1] hidden w-[52%] bg-linear-to-l from-paper/52 via-paper/16 to-transparent lg:block'></div>
      <div class='pointer-events-none absolute inset-0 z-[1] bg-linear-to-b from-paper via-paper/62 to-paper/96'></div>
      <div class='pointer-events-none absolute inset-0 z-[1] bg-paper/78 sm:bg-paper/48 lg:bg-transparent'></div>

      <header class='relative z-20 mx-auto flex max-w-7xl items-start justify-between gap-6 border-b border-ink/70 pb-4 text-xs text-ink'>
        <a
          href='/'
          class='brand-mark transition-opacity hover:opacity-72 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-command'
          aria-label='PM0 home'
        >
          <img
            src='/logo.svg'
            alt='PM0'
            class='h-8 w-auto sm:h-9'
          />
        </a>
        <nav
          class='flex flex-wrap items-center justify-end gap-x-3 gap-y-2 pt-1 font-mono text-[0.68rem] sm:gap-x-5 sm:text-[0.72rem]'
          aria-label='Primary'
        >
          <a
            href='#loop'
            class='nav-link'
          >
            Loop
          </a>
          <a
            href='#examples'
            class='nav-link hidden sm:inline'
          >
            Examples
          </a>
          <a
            href='https://github.com/KDotIndustries/pm0'
            class='nav-icon'
            aria-label='View PM0 on GitHub'
          >
            <GithubLogoIcon
              aria-hidden='true'
              className='size-4'
              weight='bold'
            />
          </a>
          <a
            href='https://x.com/Fouadktb'
            class='nav-icon'
            aria-label='Follow Fouad on X'
          >
            <XLogoIcon
              aria-hidden='true'
              className='size-4'
              weight='bold'
            />
          </a>
        </nav>
      </header>

      <div class='relative z-10 mx-auto grid min-w-0 max-w-7xl gap-12 pb-12 pt-12 lg:min-h-[76svh] lg:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.48fr)] lg:items-center lg:pb-14 lg:pt-16'>
        <div class='min-w-0'>
          <p class='fade-up max-w-full border border-command bg-paper px-3 py-2 font-mono text-[0.7rem] leading-5 text-command-deep shadow-[4px_4px_0_color-mix(in_oklch,var(--color-command)_28%,transparent)] sm:w-fit sm:text-xs'>
            Open-source PM skill for AI coding agents
          </p>
          <h1
            class='fade-up mt-6 max-w-5xl font-heading text-[clamp(3rem,10vw,4.8rem)] font-black leading-[0.92] text-ink sm:text-[clamp(3.7rem,5.9vw,5.1rem)]'
            style='animation-delay: 100ms'
            aria-label='Bring the mess. Find the move.'
          >
            <span class='block sm:hidden'>
              Bring the
              <br />
              mess.
              <br />
              Find the
              <br />
              <span class='marker-underline'>move.</span>
            </span>
            <span class='hidden sm:block'>Bring the mess.</span>
            <span class='hidden sm:block'>
              Find the <span class='marker-underline'>move.</span>
            </span>
          </h1>
          <p
            class='fade-up mt-6 max-w-full text-base leading-7 text-muted sm:max-w-2xl sm:text-lg sm:leading-8'
            style='animation-delay: 190ms'
          >
            PM0 turns customer calls, support tickets, analytics notes, GitHub issues,
            and founder memory into repo-native product context before your coding agent
            touches the code.
          </p>
          <div
            class='fade-up mt-7 max-w-2xl'
            style='animation-delay: 280ms'
          >
            <CommandCopy client:load />
            <noscript>
              <code>npx skills add KDotIndustries/pm0</code>
            </noscript>
          </div>
        </div>

        <aside
          class='ledger-stack fade-up relative hidden self-end lg:block'
          style='animation-delay: 260ms'
          aria-label='PM0 turns scattered inputs into a product move'
        >
          <div class='absolute -left-24 top-4 w-36 rotate-[-8deg] border border-ink/70 bg-evidence-blue p-3 font-mono text-xs shadow-[4px_4px_0_color-mix(in_oklch,var(--color-ink)_16%,transparent)]'>
            user interview
            <br />
            "what changed?"
          </div>
          <div class='absolute -right-7 top-16 w-32 rotate-[7deg] border border-ink/70 bg-evidence-amber p-3 font-mono text-xs shadow-[4px_4px_0_color-mix(in_oklch,var(--color-ink)_16%,transparent)]'>
            support ticket
            <br />
            export failed
          </div>
          <div class='relative border border-ink bg-paper p-5 shadow-[12px_12px_0_color-mix(in_oklch,var(--color-ink)_13%,transparent)]'>
            <p class='font-mono text-xs text-command-deep'>THE MOVE</p>
            <h2 class='mt-3 font-heading text-4xl leading-none'>Right next thing</h2>
            <ul class='mt-6 space-y-3 font-mono text-sm'>
              <li class='flex gap-3'>
                <span class='text-command-deep'>✓</span>
                Problem framed
              </li>
              <li class='flex gap-3'>
                <span class='text-command-deep'>✓</span>
                Evidence attached
              </li>
              <li class='flex gap-3'>
                <span class='text-command-deep'>✓</span>
                Options compared
              </li>
              <li class='flex gap-3'>
                <span class='text-command-deep'>✓</span>
                Prototype scoped
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section
      id='examples'
      class='border-b border-ink bg-paper px-5 py-14 sm:px-8 lg:px-12 lg:py-20'
    >
      <div class='mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.58fr_1.42fr]'>
        <div>
          <h2 class='max-w-lg font-heading text-4xl leading-none sm:text-6xl'>
            Context before code.
          </h2>
          <p class='mt-6 max-w-md leading-7 text-muted'>
            Bring the messy inputs that usually live across Slack, calls, tickets,
            analytics, docs, issues, and memory. PM0 stores the durable product
            summary in your repo, not another raw pile.
          </p>
        </div>
        <div class='grid gap-6 lg:grid-cols-[0.82fr_1.18fr]'>
          <div class='evidence-wall min-h-88 border border-ink bg-paper p-4'>
            <IntegrationLogos />
            {evidenceFiles.map(([file, note], index) => (
              <article
                class={`evidence-slip slip-${index + 1}`}
              >
                <p class='font-mono text-[0.72rem] text-ink'>{file}</p>
                <p class='mt-3 text-xs leading-5 text-muted'>{note}</p>
              </article>
            ))}
          </div>
          <div class='relative overflow-hidden border border-ink bg-ink p-5 text-paper shadow-[10px_10px_0_var(--color-command)]'>
            <div class='ledger-scan pointer-events-none absolute inset-x-0 top-0 h-16 bg-linear-to-b from-command/24 to-transparent'></div>
            <div class='flex items-center justify-between gap-4 border-b border-paper/20 pb-4 font-mono text-xs text-paper/62'>
              <span>.pm0 memory</span>
              <span>repo-native</span>
            </div>
            <div class='divide-y divide-paper/16'>
              {memoryRows.map(([kind, name, note]) => (
                <div class='grid gap-3 py-4 text-sm sm:grid-cols-[6.5rem_1fr]'>
                  <code class='text-command'>{kind}</code>
                  <div>
                    <p class='text-paper'>{name}</p>
                    <p class='mt-1 text-xs leading-5 text-paper/58'>{note}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id='loop'
      class='border-b border-ink bg-graph px-5 py-14 sm:px-8 lg:px-12 lg:py-20'
    >
      <div class='mx-auto max-w-7xl'>
        <div class='grid gap-8 lg:grid-cols-[0.58fr_1.42fr]'>
          <h2 class='max-w-4xl font-heading text-4xl leading-none sm:text-6xl'>
            Evidence to decision.
          </h2>
        </div>
        <div class='mt-12 grid border border-ink bg-paper lg:grid-cols-4'>
          {loop.map(item => (
            <article class='loop-cell min-h-72 border-b border-ink p-5 last:border-b-0 lg:border-b-0 lg:border-r lg:last:border-r-0'>
              <p class='font-mono text-xs text-command-deep'>{item.step}</p>
              <h3 class='mt-8 font-heading text-3xl leading-none'>{item.title}</h3>
              <code class='mt-5 block break-words border border-ink/35 bg-paper px-3 py-2 text-xs text-command-deep'>
                {item.command}
              </code>
              <p class='mt-5 text-sm leading-6 text-muted'>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class='border-b border-ink bg-paper px-5 py-14 sm:px-8 lg:px-12 lg:py-20'>
      <div class='mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.58fr_1.42fr]'>
        <div>
          <h2 class='max-w-xl font-heading text-4xl leading-none sm:text-6xl'>
            Fast code needs memory.
          </h2>
        </div>
        <div class='grid gap-10'>
          <p class='max-w-3xl text-lg leading-8 text-muted'>
            AI coding agents can ship changes quickly, but speed does not tell them
            which problem matters, what users already said, or which paths the team
            rejected last week. PM0 gives the agent product memory before the build
            begins.
          </p>
          <ul class='grid gap-px border border-ink bg-ink sm:grid-cols-3'>
            {principles.map(principle => (
              <li class='min-h-36 bg-paper p-5 text-lg leading-7'>{principle}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <footer class='border-t border-paper/16 bg-ink px-5 py-8 font-mono text-xs text-paper/62 sm:px-8 lg:px-12'>
      <div class='mx-auto flex max-w-7xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between'>
        <a
          href='/'
          class='inline-flex w-fit transition-opacity hover:opacity-72 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-command'
          aria-label='PM0 home'
        >
          <img
            src='/logo.svg'
            alt='PM0'
            class='h-6 w-auto brightness-0 invert'
          />
        </a>
        <p>Product memory for AI coding agents.</p>
      </div>
    </footer>
  </main>
</Layout>
