---
import { CommandCopy } from '../components/CommandCopy'
import { InputGravityHero } from '../components/InputGravityHero'
import Layout from '../layouts/layout.astro'

const recoveryRows = [
  ['route', 'not found', 'No matching product surface lives here.'],
  ['memory', '.pm0/', 'The useful context is still in the repo.'],
  ['next', '/', 'Return to the product loop.'],
]
---

<Layout
  title='404 | PM0'
  description='The PM0 page you requested could not be found.'
>
  <main class='min-h-dvh overflow-hidden bg-paper text-ink'>
    <section class='relative isolate grid min-h-dvh overflow-hidden px-5 pb-10 pt-5 sm:px-8 lg:px-12'>
      <InputGravityHero client:load />
      <div class='absolute inset-0 z-[1] bg-paper/78'></div>
      <div class='absolute inset-x-0 bottom-0 z-[1] h-64 bg-linear-to-t from-paper via-paper/90 to-transparent'></div>
      <div class='absolute inset-y-0 left-[11%] z-[1] hidden w-px bg-ink/12 lg:block'></div>
      <div class='absolute inset-y-0 right-[16%] z-[1] hidden w-px bg-ink/12 lg:block'></div>

      <header class='relative z-20 mx-auto flex w-full max-w-7xl items-center justify-between gap-6 text-xs uppercase tracking-[0.14em] text-muted'>
        <a
          href='/'
          class='text-ink transition-colors hover:text-rust focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-rust'
        >
          pm0
        </a>
        <nav
          class='flex items-center gap-4 sm:gap-6'
          aria-label='Primary'
        >
          <a
            href='https://github.com/KDotIndustries/pm0'
            class='transition-colors hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-rust'
          >
            GitHub
          </a>
          <a
            href='https://x.com/Fouadktb'
            class='transition-colors hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-rust'
          >
            DM me
          </a>
        </nav>
      </header>

      <div class='relative z-10 mx-auto grid w-full max-w-7xl items-end gap-10 py-16 lg:grid-cols-[minmax(0,0.95fr)_minmax(22rem,0.65fr)] lg:py-20'>
        <div>
          <p class='w-fit border border-ink/15 bg-limewash px-3 py-2 text-xs uppercase tracking-[0.16em] text-ink shadow-[5px_5px_0_color-mix(in_oklch,var(--color-ink)_14%,transparent)]'>
            Missing surface
          </p>
          <h1 class='mt-5 font-heading text-[clamp(5.5rem,26vw,16rem)] leading-[0.78] text-ink'>
            404
          </h1>
          <p class='mt-6 max-w-2xl text-base leading-7 text-muted sm:text-lg sm:leading-8'>
            This route has no proposal, no PRD, and no durable surface memory. Go back to the
            homepage or install PM0 from the command line.
          </p>
          <div class='mt-8 flex flex-wrap gap-4 text-sm'>
            <a
              href='/'
              class='border border-ink bg-ink px-4 py-3 text-paper transition-transform hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-rust'
            >
              Back home
            </a>
            <a
              href='https://github.com/KDotIndustries/pm0'
              class='border border-ink/20 px-4 py-3 text-ink transition-colors hover:border-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-rust'
            >
              View source
            </a>
          </div>
        </div>

        <div class='grid gap-5'>
          <div class='relative overflow-hidden border border-ink/20 bg-ink p-5 text-paper shadow-[10px_10px_0_var(--color-line)]'>
            <div class='ledger-scan pointer-events-none absolute inset-x-0 top-0 h-14 bg-linear-to-b from-limewash/20 to-transparent'></div>
            <div class='flex items-center justify-between gap-4 border-b border-paper/16 pb-4 text-xs uppercase tracking-[0.16em] text-paper/56'>
              <span>recovery log</span>
              <span>status 404</span>
            </div>
            <div class='divide-y divide-paper/12'>
              {
                recoveryRows.map(([kind, name, note]) => (
                  <div class='grid gap-3 py-4 text-sm sm:grid-cols-[5.5rem_1fr]'>
                    <code class='text-clay'>{kind}</code>
                    <div>
                      <p class='text-paper'>{name}</p>
                      <p class='mt-1 text-xs leading-5 text-paper/58'>{note}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
          <CommandCopy client:load />
          <noscript>
            <code>npx skills add KDotIndustries/pm0</code>
          </noscript>
        </div>
      </div>
    </section>
  </main>
</Layout>
